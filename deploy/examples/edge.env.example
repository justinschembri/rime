# Example edge environment for watch_file.py
# Copy to /etc/rime-edge/eltek.env on the field host.

RIME_SERVER_URL=https://rime.example.edu
RIME_APP_ID=eltek-field-01
RIME_API_KEY=replace-with-edge-secret
RIME_SENSOR_UUID=K02212-12943
RIME_WATCH_PATH=/path/to/K02212-12943 (Readings) Page 001.csv
RIME_WATCH_MODE=tail
RIME_CONTENT_TYPE=text/csv; charset=utf-8
RIME_DEBOUNCE_SECONDS=1.0
RIME_POLL_INTERVAL=0.5
